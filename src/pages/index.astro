    const scrolled = window.scrollY > 60;
    nav.classList.toggle('scrolled', scrolled);
    nav.classList.toggle('on-hero', !scrolled);
  };
  update();
  window.addEventListener('scroll', update, { passive: true });
}

// ── LANGUAGE ─────────────────────────────────────────────────
function applyLang(l) {
  curLang = l;
  const t = T[l] || T.en;
  document.documentElement.dir = l === 'ar' ? 'rtl' : 'ltr';
  document.querySelectorAll('[data-k]').forEach(el => {
    const k = el.dataset.k;
    if (t[k] !== undefined) el.innerHTML = t[k];
  });
  ['langBtn','langBtnM'].forEach(id => {
    const btn = document.getElementById(id);
    if (btn) btn.textContent = l.toUpperCase();
  });
  document.querySelectorAll('.ld-item').forEach(b => {
    b.style.color = b.dataset.l === l ? '#f8f5f1' : '';
  });
}

function initLang() {
  ['langBtn','langBtnM'].forEach((id, i) => {
    const btn = document.getElementById(id);
    const drop = document.getElementById(i === 0 ? 'langDrop' : 'langDropM');
    if (!btn || !drop) return;
    btn.addEventListener('click', e => { e.stopPropagation(); drop.classList.toggle('open'); });
    drop.querySelectorAll('.ld-item').forEach(item => {
      item.addEventListener('click', () => { applyLang(item.dataset.l); drop.classList.remove('open'); });
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.lang-drop').forEach(d => d.classList.remove('open'));
  });
  const bl = navigator.language.slice(0,2).toLowerCase();
  applyLang(['en','zh','ru','ar'].includes(bl) ? bl : 'en');
}

// ── FABS ─────────────────────────────────────────────────────
function renderFabs() {
  const g = document.getElementById('fabGrid');
  if (!g) return;
  g.innerHTML = FABS.map(f => `<button class="fb" data-fab="${f}">${f}</button>`).join('');
  g.querySelectorAll('.fb').forEach(btn => {
    btn.addEventListener('click', () => {
      const msg = document.getElementById('fMsg');
      if (msg && !msg.value) msg.value = btn.dataset.fab + ' — ';
      document.getElementById('inquiry')?.scrollIntoView({ behavior: 'smooth' });
    });
  });
}

// ── SHOWCASE ─────────────────────────────────────────────────
let scFilter = 'all';
function renderShowcase() {
  const track = document.getElementById('scTrack');
  const empty = document.getElementById('scEmpty');
  if (!track) return;
  const items = scFilter === 'all' ? SHOWCASE : SHOWCASE.filter(s => s.category === scFilter);
  if (!items.length) { track.innerHTML = ''; if (empty) empty.style.display = 'block'; return; }
  if (empty) empty.style.display = 'none';
  track.innerHTML = items.map(s => {
    const imgs = s.images ?? [];
    const slides = imgs.map(src => `<div class="sc-slide"><img src="${src}" alt="${s.title}" loading="lazy"></div>`).join('');
    const dots = imgs.length > 1
      ? `<div class="sc-dots">${imgs.map((_,i) => `<div class="sc-dot${i===0?' on':''}"></div>`).join('')}</div>`
      : '';
    return `<div class="sc-card" data-cat="${s.category}">
      <div class="sc-card-media"><div class="sc-slides">${slides}</div>${dots}</div>
      <div class="sc-info">
        <div class="sc-tag">${s.tag||s.category}</div>
        <div class="sc-title">${s.title}</div>
        ${s.meta?`<div class="sc-meta">${s.meta}</div>`:''}
      </div></div>`;
  }).join('');
  track.querySelectorAll('.sc-card').forEach(card => {
    const sl = card.querySelector('.sc-slides');
    const dots = [...card.querySelectorAll('.sc-dot')];
    if (!sl||!dots.length) return;
    sl.addEventListener('scroll', () => {
      const idx = Math.round(sl.scrollLeft / sl.clientWidth);
      dots.forEach((d,i) => d.classList.toggle('on', i===idx));
    }, { passive:true });
  });
}

function initShowcaseDrag() {
  const wrap = document.querySelector('.sc-track-wrap');
  if (!wrap) return;
  let down=false, sx=0, sl=0;
  wrap.addEventListener('mousedown', e => { down=true; sx=e.pageX-wrap.offsetLeft; sl=wrap.scrollLeft; wrap.style.cursor='grabbing'; });
  wrap.addEventListener('mouseleave', () => { down=false; wrap.style.cursor='grab'; });
  wrap.addEventListener('mouseup',   () => { down=false; wrap.style.cursor='grab'; });
  wrap.addEventListener('mousemove', e => { if(!down) return; e.preventDefault(); wrap.scrollLeft=sl-(e.pageX-wrap.offsetLeft-sx); });
}

// ── FORM ─────────────────────────────────────────────────────
function initForm() {
  const drop  = document.getElementById('fileDrop');
  const input = document.getElementById('fFiles');
  const list  = document.getElementById('fileList');
  if (drop && input && list) {
    drop.addEventListener('click', () => input.click());
    drop.addEventListener('dragover', e => { e.preventDefault(); drop.style.borderColor='rgba(248,245,241,.4)'; });
    drop.addEventListener('dragleave', () => { drop.style.borderColor=''; });
    drop.addEventListener('drop', e => {
      e.preventDefault(); drop.style.borderColor='';
      const dt = new DataTransfer();
      [...(input.files??[])].forEach(f=>dt.items.add(f));
      [...(e.dataTransfer?.files??[])].forEach(f=>dt.items.add(f));
      input.files=dt.files; renderFiles();
    });
    input.addEventListener('change', renderFiles);
    function renderFiles() {
      list.innerHTML = [...(input.files??[])].map(f=>`<div class="fi-chip">${f.name}</div>`).join('');
    }
  }

  document.getElementById('iqForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const t = T[curLang];
    const name  = document.getElementById('fName').value.trim();
    const email = document.getElementById('fEmail').value.trim();
    const gdpr  = document.getElementById('fGdpr').checked;
    if (!name||!email||!gdpr) { showMsg(t.msg_val,'err'); return; }
    const btn = document.getElementById('subBtn');
    if (btn) { btn.disabled=true; btn.textContent='…'; }
    const fd = new FormData();
    fd.append('access_key','e9868ff6-1838-4053-8bf9-5f701496acfa');
    fd.append('subject',`New DONGXI Inquiry from ${name}`);
    fd.append('name', name);
    fd.append('email', email);
    fd.append('orderType', document.querySelector('input[name=orderType]:checked')?.value||'');
    fd.append('destination', document.getElementById('fDest')?.value||'');
    fd.append('message', document.getElementById('fMsg')?.value||'');
    const files = document.getElementById('fFiles')?.files??[];
    for (let i=0;i<files.length;i++) fd.append('attachment'+i, files[i], files[i].name);
    try {
      const res  = await fetch('https://api.web3forms.com/submit',{method:'POST',body:fd});
      const json = await res.json();
      showMsg(json.success ? t.msg_ok : t.msg_err, json.success ? 'ok' : 'err');
      if (json.success) { document.getElementById('iqForm').reset(); list&&(list.innerHTML=''); }
    } catch { showMsg(t.msg_err,'err'); }
    finally { if(btn){btn.disabled=false;btn.textContent=T[curLang].btn_send;} }
  });
}

function showMsg(msg, cls) {
  const el = document.getElementById('iqMsg');
  if (!el) return;
  el.textContent = msg;
  el.className = 'iq-msg ' + cls;
}

// ── INIT ─────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  initNav();
  initLang();
  renderFabs();
  renderShowcase();
  initShowcaseDrag();
  initForm();

  document.querySelectorAll('.scf').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.scf').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      scFilter = btn.dataset.f ?? 'all';
      renderShowcase();
    });
  });
});
</script>
