<style is:global>
/* ── RESET & BASE ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #f8f5f1; color: #1a1a1a; font-family: 'Azeret Mono', monospace; -webkit-font-smoothing: antialiased; }

/* ── TOKENS ── */
:root {
  --ink:     #1a1a1a;
  --paper:   #f8f5f1;
  --paper2:  #f2ede8;
  --rust:    #c04b28;
  --border:  #e5e0d8;
  --c-w: min(100% - 48px, 1280px);
  --sec-pad: clamp(80px, 10vw, 140px);
}

/* ── TYPOGRAPHY ── */
.editorial  { font-family: 'Cormorant Garamond', 'Libre Baskerville', Georgia, serif; font-weight: 300; }
.mono       { font-family: 'Azeret Mono', monospace; }
.zh         { font-family: 'Noto Serif SC', serif; }

/* ── LAYOUT ── */
.sec-container { width: var(--c-w); margin-inline: auto; }

/* ── NAV ── */
.nav {
  position: fixed; inset-block-start: 0; inset-inline: 0; z-index: 100;
  height: 60px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding-inline: clamp(20px, 4vw, 60px);
  background: transparent;
  transition: background .4s ease, border-color .4s ease;
  border-bottom: 1px solid transparent;
}
.nav.scrolled { background: #f8f5f1; border-bottom-color: var(--border); }
.nav.on-hero  { color: #f8f5f1; }
.nav-left  { display: flex; align-items: center; gap: 32px; }
.nav-right { display: flex; align-items: center; gap: 24px; justify-content: flex-end; }
.nav-logo {
  font-family: 'Azeret Mono', monospace;
  font-size: 13px; letter-spacing: .2em;
  text-decoration: none; color: inherit;
  display: flex; align-items: center; gap: 8px;
  justify-content: center;
}
.nav-pip { width: 6px; height: 6px; border-radius: 50%; background: var(--rust); flex-shrink: 0; }
.nav-link {
  font-family: 'Azeret Mono', monospace;
  font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
  text-decoration: none; color: inherit; background: none; border: none;
  cursor: pointer; transition: opacity .15s;
}
.nav-link:hover { opacity: .5; }
.nav-shop { opacity: .65; }
.nav-mobile { display: none; align-items: center; gap: 16px; grid-column: 3; justify-content: flex-end; }
@media(max-width: 700px) {
  .nav { grid-template-columns: auto 1fr; }
  .nav-left, .nav-right { display: none; }
  .nav-mobile { display: flex; }
  .nav-logo { justify-content: flex-start; }
}

/* Lang dropdown */
.lang-wrap { position: relative; }
.lang-drop {
  display: none; position: absolute; top: calc(100% + 10px); right: 0;
  background: var(--ink); border: none;
  padding: 8px 0; min-width: 110px; z-index: 200;
}
.lang-drop.open { display: block; }
.ld-item {
  display: block; width: 100%; text-align: left;
  padding: 9px 16px;
  font-family: 'Azeret Mono', monospace; font-size: 9px; letter-spacing: .1em;
  color: rgba(248,245,241,.5); background: none; border: none; cursor: pointer;
  transition: color .1s;
}
.ld-item:hover { color: #f8f5f1; }

/* ── BUTTONS ── */
.btn-ghost {
  display: inline-block;
  font-family: 'Azeret Mono', monospace;
  font-size: 10px; letter-spacing: .16em; text-transform: uppercase;
  text-decoration: none;
  padding: 14px 36px;
  border: 1px solid currentColor;
  background: transparent; color: inherit;
  transition: background .25s, color .25s;
  cursor: pointer; border-radius: 0;
  white-space: nowrap;
