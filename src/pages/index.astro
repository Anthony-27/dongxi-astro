// ── SHOWCASE DATA ────────────────────────────────────────────
let SHOWCASE = [];
try { SHOWCASE = JSON.parse(showcaseJSON); } catch(e) {}

// ── RENDER FABS ──────────────────────────────────────────────
function renderFabs() {
  const g = document.getElementById('fabGrid');
  if (!g) return;
  g.innerHTML = FABS.map(f =>
    `<button class="fb">${f}</button>`
  ).join('');
}

// ── RENDER SHOWCASE ──────────────────────────────────────────
let scFilter = 'all';
function renderShowcase() {
  const track = document.getElementById('scTrack');
  const empty = document.getElementById('scEmpty');
  if (!track) return;
  const items = scFilter === 'all' ? SHOWCASE : SHOWCASE.filter(s => s.category === scFilter);
  if (items.length === 0) {
    track.innerHTML = '';
    if (empty) empty.style.display = 'block';
    return;
  }
  if (empty) empty.style.display = 'none';
  track.innerHTML = items.map(s => {
    const imgs = s.images ?? [];
    const slidesHtml = imgs.map(src =>
      `<div class="sc-slide"><img src="${src}" alt="${s.title}" loading="lazy"></div>`
    ).join('');
    const dotsHtml = imgs.length > 1
      ? `<div class="sc-dots">${imgs.map((_,i) => `<div class="sc-dot${i===0?' on':''}"></div>`).join('')}</div>`
      : '';
    return `
      <div class="sc-card" data-cat="${s.category}">
        <div class="sc-card-media">
          <div class="sc-slides">${slidesHtml}</div>
          ${dotsHtml}
        </div>
        <div class="sc-info">
          <div class="sc-tag">${s.tag || s.category}</div>
          <div class="sc-title">${s.title}</div>
          ${s.meta ? `<div class="sc-meta">${s.meta}</div>` : ''}
        </div>
      </div>`;
  }).join('');

  // Bind slide dot sync
  track.querySelectorAll('.sc-card').forEach(card => {
    const sl = card.querySelector('.sc-slides');
    const dots = [...(card.querySelectorAll('.sc-dot') ?? [])];
    if (!sl || dots.length === 0) return;
    sl.addEventListener('scroll', () => {
      const idx = Math.round(sl.scrollLeft / sl.clientWidth);
      dots.forEach((d,i) => d.classList.toggle('on', i === idx));
    }, { passive: true });
  });
}

// ── APPLY LANGUAGE ───────────────────────────────────────────
function applyLang(l) {
  curLang = l;
  const t = T[l] || T.en;
  const dir = l === 'ar' ? 'rtl' : 'ltr';
  document.documentElement.dir = dir;
  document.querySelectorAll('[data-k]').forEach(el => {
    const k = el.dataset.k;
    if (t[k] !== undefined) el.innerHTML = t[k];
  });
  document.querySelectorAll('.ld-item').forEach(b => {
    b.classList.toggle('active', b.dataset.l === l);
  });
  const btn = document.getElementById('langBtn');
  if (btn) btn.textContent = l.toUpperCase() + ' ▾';
}

// ── APPLY CURRENCY ───────────────────────────────────────────
function applyCurr(c) {
  curCurr = c;
  const rate = C[c] || 1;
  const sym  = SYM[c] || '$';
  document.querySelectorAll('.curr-val').forEach(el => {
    const base = parseFloat(el.dataset.base || '0');
    const unit = el.dataset.unit || '';
    el.textContent = sym + Math.round(base * rate).toLocaleString() + ' ' + unit;
  });
  document.querySelectorAll('.curr-btn').forEach(b => {
    b.classList.toggle('on', b.dataset.c === c);
  });
}

// ── FORM STEPS ───────────────────────────────────────────────
function goS(n) {
  // Validate current step before going forward
  const cur = parseInt(document.querySelector('.iq-step.active')?.id?.replace('step','') || '1');
  if (n > cur) {
    if (cur === 1) {
      const name  = document.getElementById('fName').value.trim();
      const email = document.getElementById('fEmail').value.trim();
      const dest  = document.getElementById('fDest').value;
      if (!name || !email || !dest) {
        showMsg(T[curLang].msg_val, 'err');
        return;
      }
    }
  }
  document.querySelectorAll('.iq-step').forEach((s,i) => {
    s.classList.toggle('active', i + 1 === n);
  });
  document.querySelectorAll('.sb-item').forEach((s,i) => {
    s.classList.toggle('active', i + 1 === n);
  });
  document.getElementById('iqMsg')?.classList.remove('ok','err');
}

function showMsg(msg, cls) {
  const el = document.getElementById('iqMsg');
  if (!el) return;
  el.textContent = msg;
  el.className = 'iq-msg ' + cls;
}

// ── SUBMIT ───────────────────────────────────────────────────
async function submitF(e) {
  e.preventDefault();
  const t = T[curLang];
  const name  = document.getElementById('fName').value.trim();
  const email = document.getElementById('fEmail').value.trim();
  const gdpr  = document.getElementById('fGdpr').checked;
  if (!name || !email || !gdpr) { showMsg(t.msg_val,'err'); return; }

  const btn = document.getElementById('subBtn');
  if (btn) { btn.disabled = true; btn.textContent = '…'; }

  const fd = new FormData();
  fd.append('access_key', '9e7e8d98-fd52-4e0a-aa56-f0413b9e1a66');
  fd.append('name',    name);
  fd.append('email',   email);
  fd.append('company', document.getElementById('fCo')?.value || '');
  fd.append('destination', document.getElementById('fDest')?.value || '');
  fd.append('orderType',   document.querySelector('input[name=orderType]:checked')?.value || '');
  fd.append('quantity',    document.getElementById('fQty')?.value || '');
  fd.append('material',    document.getElementById('fMat')?.value || '');
  fd.append('message',     document.getElementById('fMsg')?.value || '');
  fd.append('subject', `New DONGXI Inquiry from ${name}`);

  const files = document.getElementById('fFiles')?.files ?? [];
  for (let i = 0; i < files.length; i++) {
    fd.append('attachment' + i, files[i], files[i].name);
  }

  try {
    const res = await fetch('https://api.web3forms.com/submit', { method:'POST', body: fd });
    const json = await res.json();
    if (json.success) {
      showMsg(t.msg_ok, 'ok');
      document.getElementById('iqForm')?.reset();
      document.getElementById('fileList').innerHTML = '';
      goS(1);
    } else {
      showMsg(t.msg_err, 'err');
    }
  } catch {
    showMsg(t.msg_err, 'err');
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = T[curLang].btn_send; }
  }
}

// ── DRAG-SCROLL FOR SHOWCASE ─────────────────────────────────
function initDragScroll() {
  const wrap = document.querySelector('.sc-track-wrap');
  if (!wrap) return;
  let isDown = false, startX = 0, scrollLeft = 0;
  wrap.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - wrap.offsetLeft; scrollLeft = wrap.scrollLeft; wrap.style.cursor='grabbing'; });
  wrap.addEventListener('mouseleave', () => { isDown = false; wrap.style.cursor='grab'; });
  wrap.addEventListener('mouseup',   () => { isDown = false; wrap.style.cursor='grab'; });
  wrap.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    wrap.scrollLeft = scrollLeft - (e.pageX - wrap.offsetLeft - startX);
  });
}

// ── FILE INPUT ───────────────────────────────────────────────
function initFileInput() {
  const drop = document.getElementById('fileDrop');
  const input = document.getElementById('fFiles');
  const list  = document.getElementById('fileList');
  if (!drop || !input || !list) return;
  drop.addEventListener('click', () => input.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.style.borderColor='var(--rust)'; });
  drop.addEventListener('dragleave', () => { drop.style.borderColor=''; });
  drop.addEventListener('drop', e => {
    e.preventDefault(); drop.style.borderColor='';
    const dt = new DataTransfer();
    [...(input.files??[])].forEach(f => dt.items.add(f));
    [...(e.dataTransfer?.files??[])].forEach(f => dt.items.add(f));
    input.files = dt.files;
    renderFileList();
  });
  input.addEventListener('change', renderFileList);
  function renderFileList() {
    list.innerHTML = [...(input.files??[])].map(f =>
      `<div class="fi-chip">${f.name}</div>`
    ).join('');
  }
}

// ── TOPBAR SCROLL ────────────────────────────────────────────
function initTopbar() {
  const top = document.getElementById('top');
  if (!top) return;
  window.addEventListener('scroll', () => {
    top.style.background = window.scrollY > 20
      ? 'rgba(28,25,20,.98)'
      : 'rgba(28,25,20,.97)';
  }, { passive: true });
}

// ── INIT ─────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  renderFabs();
  renderShowcase();
  initDragScroll();
  initFileInput();
  initTopbar();
  applyLang('en');
  applyCurr('USD');

  // Lang toggle
  document.getElementById('langBtn')?.addEventListener('click', () => {
    document.getElementById('langDrop')?.classList.toggle('open');
  });
  document.querySelectorAll('.ld-item').forEach(btn => {
    btn.addEventListener('click', () => {
      applyLang(btn.dataset.l);
      document.getElementById('langDrop')?.classList.remove('open');
    });
  });
  document.addEventListener('click', e => {
    if (!e.target.closest('.lang-wrap')) {
      document.getElementById('langDrop')?.classList.remove('open');
    }
  });

  // Currency
  document.querySelectorAll('.curr-btn').forEach(btn => {
    btn.addEventListener('click', () => applyCurr(btn.dataset.c));
  });

  // Showcase filters
  document.querySelectorAll('.scf').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.scf').forEach(b => b.classList.remove('on'));
      btn.classList.add('on');
      scFilter = btn.dataset.f ?? 'all';
      renderShowcase();
    });
  });

  // Form submit
  document.getElementById('iqForm')?.addEventListener('submit', submitF);
});
