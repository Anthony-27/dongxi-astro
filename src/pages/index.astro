---
import Base from '../layouts/Base.astro';
import { getShowcase, urlFor } from '../lib/sanity';

const showcaseItems = await getShowcase();
const showcaseJSON = JSON.stringify(
  showcaseItems.map((s: any) => ({
    id:       s._id,
    title:    s.title,
    tag:      s.tag   ?? '',
    category: s.category ?? '',
    meta:     s.meta  ?? '',
    images:   (s.images ?? []).map((img: any) =>
      urlFor(img).width(800).auto('format').url()
    ),
  }))
);
---
<Base
  title="DONGXI — Guangzhou Fabric & Garment Manufacturer | B2B Production"
  description="Source fabrics & custom garments direct from Guangzhou. Silk, lace, embroidery & more. 48hr quote. MOQ from 50m."
  ogUrl="https://dongxi.io"
>

<!-- TOPBAR -->
<header class="topbar" id="top">
  <a href="/" class="logo"><span class="logo-pip"></span>DONGXI</a>
  <nav class="top-nav">
    <a href="#why"     class="tnl" data-k="nav_why">Why Us</a>
    <a href="#catalog" class="tnl" data-k="nav_cat">Catalog</a>
    <a href="#inquiry" class="tnl" data-k="nav_inq">Inquiry</a>
    <a href="/shop" class="shop-link">Shop <span class="shop-link-arrow">↗</span></a>
  </nav>
  <a href="/shop" class="shop-mobile-btn">Shop ↗</a>
  <div class="top-r">
    <div class="lang-wrap">
      <button class="lang-cur" id="langBtn">EN ▾</button>
      <div class="lang-drop" id="langDrop">
        <button class="ld-item active" data-l="en">EN · English</button>
        <button class="ld-item" data-l="zh">ZH · 中文</button>
        <button class="ld-item" data-l="ru">RU · Русский</button>
        <button class="ld-item" data-l="ar">AR · العربية</button>
      </div>
    </div>
    <a href="#inquiry" class="tcta" data-k="cta_inq">Get a Quote</a>
  </div>
</header>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-inner content-w">
    <div class="hero-text">
      <div class="sec-label" data-k="h_label">Guangzhou · Direct Factory</div>
      <h1 class="hero-h">
        <span data-k="h_line1">Fabric.</span><br>
        <em data-k="h_line2">Built for</em><br>
        <span data-k="h_line3">your brand.</span>
      </h1>
      <p class="hero-sub" data-k="h_sub">From photo or sample to finished garment — silk, lace, embroidery, custom weaves. 48-hour quote. MOQ from 50 m.</p>
      <div class="hero-btns">
        <a href="#inquiry" class="tcta hero-cta-main" data-k="cta_inq">Get a Quote</a>
        <a href="/shop"    class="tcta hero-cta-shop">Shop Ready Stock ↗</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hs-item">
        <span class="hs-n">48h</span>
        <span class="hs-l" data-k="hb_quote">quote</span>
      </div>
      <div class="hs-div"></div>
      <div class="hs-item">
        <span class="hs-n">12+</span>
        <span class="hs-l" data-k="bs_yr">years</span>
      </div>
      <div class="hs-div"></div>
      <div class="hs-item">
        <span class="hs-n">50+</span>
        <span class="hs-l" data-k="bs_ct">countries</span>
      </div>
    </div>
  </div>
</section>

<!-- WHY — 3 cards -->
<section class="why-sec" id="why">
  <div class="content-w">
    <div class="sec-label" data-k="why_label">Why DONGXI</div>
    <div class="why-grid">
      <div class="wc">
        <div class="wc-icon">◈</div>
        <div class="wc-t" data-k="wc1t">Direct Factory</div>
        <div class="wc-d" data-k="wc1d">No middlemen. You talk to the maker. Margins stay with your brand.</div>
      </div>
      <div class="wc">
        <div class="wc-icon">⟳</div>
        <div class="wc-t" data-k="wc2t">Fast Turnaround</div>
        <div class="wc-d" data-k="wc2d">Sample in 7–14 days. Bulk in 30–45 days. MOQ from 50 m / 50 pcs.</div>
      </div>
      <div class="wc">
        <div class="wc-icon">❋</div>
        <div class="wc-t" data-k="wc3t">Full Service</div>
        <div class="wc-d" data-k="wc3d">Design · sampling · CMT · packaging · shipping — one contact.</div>
      </div>
    </div>
  </div>
</section>

<!-- CATALOG -->
<section class="catalog-sec" id="catalog">
  <div class="content-w">
    <div class="sec-label" data-k="cat_label">What we make</div>
    <h2 class="sec-h2" data-k="cat_h">Our catalog</h2>
    <p class="cat-sub" data-k="cat_sub">Click any material to start an inquiry.</p>
    <div class="fab-grid" id="fabGrid"></div>
  </div>
</section>

<!-- SHOWCASE -->
<section class="showcase-sec" id="showcase">
  <div class="content-w">
    <div class="sc-head">
      <div>
        <div class="sec-label" data-k="sc_label">From our factory</div>
        <h2 class="sec-h2" data-k="sc_h">Recent work.</h2>
      </div>
      <div class="sc-filters" id="scFilters">
        <button class="scf on" data-f="all"        data-k="scf_all">All</button>
        <button class="scf"    data-f="garment"    data-k="scf_gar">Garments</button>
        <button class="scf"    data-f="fabric"     data-k="scf_fab">Fabrics</button>
        <button class="scf"    data-f="embroidery" data-k="scf_emb">Embroidery</button>
      </div>
    </div>
    <div class="sc-track-wrap">
      <div class="sc-track" id="scTrack"></div>
    </div>
    <p class="sc-empty" id="scEmpty" style="display:none">No items yet — check back soon.</p>
  </div>
</section>

<!-- INQUIRY — single step -->
<section class="inq-sec" id="inquiry">
  <div class="content-w inq-layout">

    <div class="inq-left">
      <div class="sec-label" data-k="inq_label">Start your order</div>
      <h2 class="sec-h2" data-k="inq_h">Get a quote<br><em>in 48 hours.</em></h2>
      <div class="inq-facts">
        <div class="if-row"><span class="if-dot"></span><span data-k="ps1d">Share photos, sketches or samples.</span></div>
        <div class="if-row"><span class="if-dot"></span><span data-k="ps2d">We reply within 48 hours with options & price.</span></div>
        <div class="if-row"><span class="if-dot"></span><span data-k="ps3d">Sample shipped to you for approval before bulk.</span></div>
      </div>
    </div>

    <form id="iqForm" class="inq-form" novalidate>
      <div class="iq-row two-col">
        <div>
          <label class="iq-label" data-k="f_name">Name *</label>
          <input class="iq-in" id="fName" type="text" required autocomplete="name">
        </div>
        <div>
          <label class="iq-label" data-k="f_email">Email *</label>
          <input class="iq-in" id="fEmail" type="email" required autocomplete="email">
        </div>
      </div>
      <div class="iq-row">
        <label class="iq-label" data-k="f_msg">Tell us what you need</label>
        <textarea class="iq-in" id="fMsg" rows="4" data-k-ph="msg_ph" placeholder="Fabric type, quantity, destination, deadline…"></textarea>
      </div>
      <div class="iq-row">
        <label class="iq-label" data-k="f_files">Reference photos / tech pack (optional)</label>
        <label class="file-drop" id="fileDrop">
          <input type="file" id="fFiles" multiple accept="image/*,.pdf,.ai,.eps" style="display:none">
          <div class="fd-inner">
            <div class="fd-icon">⊕</div>
            <div class="fd-txt" data-k="fd_txt">Drop files or click to browse</div>
            <div class="fd-sub" data-k="fd_sub">JPG · PNG · PDF · AI</div>
          </div>
        </label>
        <div class="file-list" id="fileList"></div>
      </div>
      <div class="iq-row iq-bottom">
        <label class="ropt">
          <input type="checkbox" id="fGdpr" required>
          <span data-k="f_gdpr">I agree to be contacted regarding my inquiry.</span>
        </label>
        <button type="submit" class="tcta inq-submit" id="subBtn" data-k="btn_send">Send Inquiry →</button>
      </div>
      <div id="iqMsg" class="iq-msg"></div>
    </form>

  </div>
</section>

<!-- FOOTER -->
<footer class="site-foot">
  <div class="content-w sf-inner">
    <div class="sf-brand">
      <a href="/" class="logo"><span class="logo-pip"></span>DONGXI</a>
      <p class="sf-tag" data-k="ft_tag">Guangzhou textile manufacturer since 2012.</p>
    </div>
    <div class="sf-links">
      <a href="#why"     data-k="nav_why">Why Us</a>
      <a href="#catalog" data-k="nav_cat">Catalog</a>
      <a href="#inquiry" data-k="nav_inq">Inquiry</a>
      <a href="/shop">Shop</a>
    </div>
    <div class="sf-contact">
      <a href="mailto:hello@dongxi.io">hello@dongxi.io</a>
      <span data-k="ft_addr">Guangzhou, China · 广州</span>
    </div>
  </div>
  <div class="sf-copy">
    <span>© 2025 DONGXI · 广州东西贸易有限公司</span>
    <span data-k="ft_rights">All rights reserved</span>
  </div>
</footer>

</Base>

<style is:global>
body { background: var(--paper); color: var(--ink); }

/* ── TOPBAR ── */
.topbar { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:0 32px; height:56px; background:rgba(28,25,20,.97); backdrop-filter:blur(8px); border-bottom:1px solid rgba(240,235,224,.06); }
.logo { font-family:'Azeret Mono',monospace; font-size:13px; letter-spacing:.18em; color:var(--paper); text-decoration:none; display:flex; align-items:center; gap:8px; }
.logo-pip { width:6px; height:6px; border-radius:50%; background:var(--rust); display:inline-block; }
.top-nav { display:flex; align-items:center; gap:24px; }
.top-nav .tnl { font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.12em; text-transform:uppercase; color:rgba(240,235,224,.45); text-decoration:none; transition:color .15s; }
.top-nav .tnl:hover { color:var(--paper); }
@media(max-width:760px){ .top-nav { display:none; } }
.top-r { display:flex; align-items:center; gap:14px; }

/* Shop link in nav */
.shop-link { font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.14em; text-transform:uppercase; color:var(--paper); text-decoration:none; padding:7px 16px; border:1px solid rgba(240,235,224,.3); border-radius:2px; display:inline-flex; align-items:center; gap:6px; transition:background .15s, border-color .15s; position:relative; overflow:hidden; }
.shop-link::before { content:''; position:absolute; inset:0; background:var(--rust); transform:translateX(-101%); transition:transform .22s cubic-bezier(.4,0,.2,1); }
.shop-link:hover::before { transform:translateX(0); }
.shop-link:hover { border-color:var(--rust); }
.shop-link span, .shop-link-arrow { position:relative; z-index:1; }
.shop-link-arrow { font-size:11px; transition:transform .15s; }
.shop-link:hover .shop-link-arrow { transform:translate(2px,-2px); }

/* Mobile shop btn */
.shop-mobile-btn { display:none; font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.14em; text-transform:uppercase; color:var(--paper); text-decoration:none; padding:7px 16px; background:var(--rust); border-radius:2px; transition:background .15s; }
.shop-mobile-btn:hover { background:var(--rust2); }
@media(max-width:760px){ .shop-mobile-btn { display:inline-block; } }

/* Lang dropdown */
.lang-wrap { position:relative; }
.lang-cur { font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.1em; color:rgba(240,235,224,.45); background:transparent; border:none; cursor:none; padding:4px 0; transition:color .15s; }
.lang-cur:hover { color:var(--paper); }
.lang-drop { display:none; position:absolute; top:calc(100% + 8px); right:0; background:var(--ink2); border:1px solid rgba(240,235,224,.1); border-radius:4px; padding:6px 0; min-width:140px; z-index:200; }
.lang-drop.open { display:block; }
.ld-item { display:block; width:100%; text-align:left; padding:8px 14px; font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.08em; color:rgba(240,235,224,.5); background:transparent; border:none; cursor:none; transition:color .12s; }
.ld-item:hover, .ld-item.active { color:var(--paper); }

/* CTA */
.tcta { display:inline-block; font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.14em; text-transform:uppercase; text-decoration:none; padding:10px 22px; background:var(--rust); color:var(--paper); border:none; cursor:none; transition:background .15s; border-radius:2px; white-space:nowrap; }
.tcta:hover { background:var(--rust2); }

/* ── HERO ── */
.hero { padding:140px 0 100px; min-height:92vh; display:flex; align-items:center; }
.hero-inner { display:flex; align-items:flex-end; justify-content:space-between; gap:48px; flex-wrap:wrap; }
.hero-text { max-width:600px; }
.hero-h { font-size:clamp(56px,9vw,108px); font-weight:400; line-height:1.0; margin:14px 0 24px; }
.hero-h em { font-style:italic; color:var(--rust); }
.hero-sub { font-family:'Azeret Mono',monospace; font-size:11px; line-height:2; color:rgba(28,25,20,.45); max-width:440px; margin-bottom:36px; }
.hero-btns { display:flex; gap:12px; flex-wrap:wrap; }
.hero-cta-main { padding:14px 32px; font-size:10px; letter-spacing:.16em; }
.hero-cta-shop { padding:14px 32px; font-size:10px; letter-spacing:.16em; background:transparent; border:1px solid rgba(28,25,20,.2); color:var(--ink); }
.hero-cta-shop:hover { background:var(--ink); color:var(--paper); border-color:var(--ink); }

/* Hero stats strip */
.hero-stats { display:flex; align-items:center; gap:0; flex-shrink:0; }
.hs-item { display:flex; flex-direction:column; align-items:center; padding:0 32px; }
.hs-n { font-family:'Libre Baskerville',serif; font-size:clamp(28px,4vw,48px); color:var(--ink); }
.hs-l { font-family:'Azeret Mono',monospace; font-size:8px; letter-spacing:.12em; text-transform:uppercase; color:rgba(28,25,20,.35); margin-top:4px; }
.hs-div { width:1px; height:40px; background:var(--line); }
@media(max-width:760px){ .hero-stats { display:none; } }

/* ── WHY ── */
.why-sec { padding:80px 0; border-top:1px solid var(--line); }
.why-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:0; border:1px solid var(--line); margin-top:40px; }
@media(max-width:680px){ .why-grid { grid-template-columns:1fr; } }
.wc { padding:40px 36px; border-right:1px solid var(--line); }
.wc:last-child { border-right:none; }
@media(max-width:680px){ .wc { border-right:none; border-bottom:1px solid var(--line); } }
.wc:last-child { border-bottom:none; }
.wc-icon { font-size:22px; margin-bottom:20px; color:var(--rust); }
.wc-t { font-size:15px; font-weight:600; margin-bottom:10px; }
.wc-d { font-family:'Azeret Mono',monospace; font-size:10px; line-height:1.9; color:rgba(28,25,20,.45); }

/* ── CATALOG ── */
.catalog-sec { padding:80px 0; background:var(--paper2); border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
.cat-sub { font-family:'Azeret Mono',monospace; font-size:10px; color:rgba(28,25,20,.38); margin:8px 0 32px; }
.fab-grid { display:flex; flex-wrap:wrap; gap:10px; }
.fb { font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.1em; text-transform:uppercase; padding:10px 20px; border:1px solid var(--line); border-radius:100px; color:rgba(28,25,20,.55); background:#fff; cursor:none; transition:all .18s; }
.fb:hover { background:var(--rust); border-color:var(--rust); color:var(--paper); transform:translateY(-1px); }

/* ── SHOWCASE ── */
.showcase-sec { padding:80px 0; overflow:hidden; }
.sc-head { display:flex; align-items:flex-end; justify-content:space-between; gap:20px; flex-wrap:wrap; margin-bottom:36px; }
.sc-filters { display:flex; gap:8px; flex-wrap:wrap; }
.scf { font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.1em; text-transform:uppercase; padding:7px 14px; background:transparent; border:1px solid rgba(28,25,20,.15); color:rgba(28,25,20,.4); cursor:none; transition:all .15s; border-radius:2px; }
.scf.on, .scf:hover { background:var(--rust); border-color:var(--rust); color:var(--paper); }
.sc-track-wrap { overflow-x:auto; scrollbar-width:none; cursor:grab; }
.sc-track-wrap::-webkit-scrollbar { display:none; }
.sc-track { display:flex; gap:16px; padding-bottom:8px; width:max-content; }
.sc-card { width:280px; flex:0 0 280px; border-radius:4px; overflow:hidden; background:#fff; border:1px solid var(--line); transition:transform .25s, box-shadow .25s; }
.sc-card:hover { transform:translateY(-4px); box-shadow:0 16px 40px rgba(28,25,20,.1); }
@media(max-width:600px){ .sc-card { width:230px; flex:0 0 230px; } }
.sc-card-media { position:relative; aspect-ratio:3/4; overflow:hidden; background:var(--paper2); }
.sc-slides { display:flex; width:100%; height:100%; overflow-x:scroll; scroll-snap-type:x mandatory; scrollbar-width:none; }
.sc-slides::-webkit-scrollbar { display:none; }
.sc-slide { flex:0 0 100%; scroll-snap-align:start; }
.sc-slide img { width:100%; height:100%; object-fit:cover; display:block; }
.sc-dots { position:absolute; bottom:8px; left:50%; transform:translateX(-50%); display:flex; gap:4px; pointer-events:none; }
.sc-dot { width:4px; height:4px; border-radius:50%; background:rgba(28,25,20,.2); }
.sc-dot.on { background:var(--rust); }
.sc-info { padding:14px 16px; }
.sc-tag { font-family:'Azeret Mono',monospace; font-size:8px; letter-spacing:.1em; text-transform:uppercase; color:var(--rust); }
.sc-title { font-size:14px; margin-top:4px; line-height:1.3; font-weight:500; }
.sc-meta { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(28,25,20,.38); margin-top:4px; }
.sc-empty { font-family:'Azeret Mono',monospace; font-size:11px; color:rgba(28,25,20,.35); padding:48px 0; }

/* ── INQUIRY ── */
.inq-sec { padding:100px 0; background:var(--paper2); border-top:1px solid var(--line); }
.inq-sec em { color:var(--rust); font-style:italic; }
.inq-layout { display:grid; grid-template-columns:1fr 1.6fr; gap:80px; align-items:start; }
@media(max-width:860px){ .inq-layout { grid-template-columns:1fr; gap:48px; } }
.inq-left { padding-top:8px; }
.inq-facts { margin-top:32px; display:flex; flex-direction:column; gap:14px; }
.if-row { display:flex; align-items:flex-start; gap:12px; font-family:'Azeret Mono',monospace; font-size:10px; line-height:1.8; color:rgba(28,25,20,.5); }
.if-dot { width:5px; height:5px; border-radius:50%; background:var(--rust); flex-shrink:0; margin-top:7px; }
.inq-form { display:flex; flex-direction:column; gap:0; }
.iq-row { margin-bottom:20px; }
.iq-row.two-col { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
@media(max-width:500px){ .iq-row.two-col { grid-template-columns:1fr; } }
.iq-label { display:block; font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.08em; text-transform:uppercase; color:rgba(28,25,20,.45); margin-bottom:8px; }
.iq-in { width:100%; padding:12px 14px; font-family:'Azeret Mono',monospace; font-size:11px; color:var(--ink); background:#fff; border:1px solid rgba(28,25,20,.12); border-radius:3px; outline:none; transition:border .15s; box-sizing:border-box; }
.iq-in:focus { border-color:var(--rust); }
textarea.iq-in { resize:vertical; }
.file-drop { display:block; border:1px dashed rgba(28,25,20,.18); border-radius:4px; padding:28px; text-align:center; cursor:none; transition:border .15s, background .15s; }
.file-drop:hover { border-color:var(--rust); background:rgba(192,75,40,.03); }
.fd-icon { font-size:20px; color:rgba(28,25,20,.18); margin-bottom:6px; }
.fd-txt { font-family:'Azeret Mono',monospace; font-size:10px; color:rgba(28,25,20,.45); }
.fd-sub { font-family:'Azeret Mono',monospace; font-size:8px; color:rgba(28,25,20,.28); margin-top:3px; }
.file-list { margin-top:10px; display:flex; flex-wrap:wrap; gap:8px; }
.fi-chip { font-family:'Azeret Mono',monospace; font-size:9px; padding:5px 10px; background:rgba(28,25,20,.06); border-radius:100px; color:rgba(28,25,20,.55); }
.iq-bottom { display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-top:4px; }
.ropt { display:flex; align-items:flex-start; gap:10px; font-family:'Azeret Mono',monospace; font-size:10px; color:rgba(28,25,20,.5); cursor:none; line-height:1.6; }
.ropt input { margin-top:2px; accent-color:var(--rust); cursor:none; flex-shrink:0; }
.inq-submit { padding:14px 36px; font-size:10px; letter-spacing:.16em; }
.iq-msg { margin-top:14px; font-family:'Azeret Mono',monospace; font-size:10px; padding:12px 16px; border-radius:3px; display:none; }
.iq-msg.ok  { background:rgba(60,140,60,.08); color:#2d7a2d; display:block; }
.iq-msg.err { background:rgba(180,40,40,.07); color:#a32020; display:block; }

/* ── FOOTER ── */
.site-foot { background:var(--ink); color:var(--paper); padding:64px 0 0; }
.sf-inner { display:grid; grid-template-columns:1fr auto auto; gap:56px; align-items:start; }
@media(max-width:700px){ .sf-inner { grid-template-columns:1fr; gap:32px; } }
.sf-tag { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(240,235,224,.28); margin-top:12px; line-height:1.8; }
.sf-links { display:flex; flex-direction:column; gap:12px; }
.sf-links a { font-family:'Azeret Mono',monospace; font-size:9px; letter-spacing:.08em; color:rgba(240,235,224,.38); text-decoration:none; transition:color .12s; }
.sf-links a:hover { color:var(--paper); }
.sf-contact { display:flex; flex-direction:column; gap:10px; }
.sf-contact a { font-family:'Azeret Mono',monospace; font-size:10px; color:rgba(240,235,224,.5); text-decoration:none; }
.sf-contact a:hover { color:var(--paper); }
