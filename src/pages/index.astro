// ── CURRENCIES ──────────────────────────────────────────────
const C = { USD:1, CNY:7.25, RUB:90, AED:3.67 };
const SYM = { USD:'$', CNY:'¥', RUB:'₽', AED:'AED ' };
let curLang = 'en', curCurr = 'USD';

// ── CATALOG FABRICS ──────────────────────────────────────────
const FABS = [
  'Silk Charmeuse','Silk Chiffon','Silk Satin','Raw Silk',
  'Jacquard Weave','Brocade','Velvet','Corduroy',
  'Cotton Poplin','Cotton Twill','Cotton Canvas','Linen',
