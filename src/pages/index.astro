---
import Base from '../layouts/Base.astro';
import { getShowcase, urlFor } from '../lib/sanity';

const WA = import.meta.env.PUBLIC_WA_NUMBER  ?? '';
const TG = import.meta.env.PUBLIC_TG_USERNAME ?? 'dongxiiobot';

const showcaseItems = await getShowcase();
const showcaseJSON = JSON.stringify(
  showcaseItems.map((s: any) => ({
    id:       s._id,
    title:    s.title,
    tag:      s.tag   ?? '',
    category: s.category ?? '',
    meta:     s.meta  ?? '',
    images:   (s.images ?? []).map((img: any) =>
      urlFor(img).width(900).auto('format').url()
    ),
  }))
);
---
<Base
  title="DONGXI — Guangzhou Fabric & Garment Manufacturer"
  description="Direct factory in Guangzhou. Silk, lace, embroidery, custom weaves. 48-hour quote. MOQ from 50m."
  ogUrl="https://dongxi.io"
>

<!-- NAV -->
<header class="nav" id="nav">
  <nav class="nav-left">
    <a href="#catalog" class="nav-link" data-k="nav_cat">Catalog</a>
    <a href="#showcase" class="nav-link" data-k="nav_sc">Work</a>
  </nav>
  <a href="/" class="nav-logo"><span class="nav-pip"></span>DONGXI</a>
  <nav class="nav-right">
    <a href="#inquiry" class="nav-link" data-k="nav_inq">Inquiry</a>
    <a href="/shop" class="nav-link nav-shop" data-k="nav_shop">Shop ↗</a>
    <div class="lang-wrap">
      <button class="nav-link lang-cur" id="langBtn">EN</button>
      <div class="lang-drop" id="langDrop">
        <button class="ld-item" data-l="en">English</button>
        <button class="ld-item" data-l="zh">中文</button>
        <button class="ld-item" data-l="ru">Русский</button>
        <button class="ld-item" data-l="ar">العربية</button>
      </div>
    </div>
  </nav>
  <!-- mobile -->
  <div class="nav-mobile">
    <a href="/shop" class="nav-link nav-shop">Shop ↗</a>
    <div class="lang-wrap">
      <button class="nav-link lang-cur" id="langBtnM">EN</button>
      <div class="lang-drop" id="langDropM">
        <button class="ld-item" data-l="en">English</button>
        <button class="ld-item" data-l="zh">中文</button>
        <button class="ld-item" data-l="ru">Русский</button>
        <button class="ld-item" data-l="ar">العربية</button>
      </div>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <p class="hero-eyebrow" data-k="h_label">Guangzhou · Direct Factory</p>
    <h1 class="hero-h">
      <span data-k="h_line1">Fabric</span><br>
      <em data-k="h_line2">for your</em><br>
      <span data-k="h_line3">brand.</span>
    </h1>
    <div class="hero-actions">
      <a href="#inquiry" class="btn-ghost btn-light" data-k="cta_inq">Get a Quote</a>
      <a href="/shop"    class="btn-solid-rust" data-k="cta_shop">Shop Ready Stock ↗</a>
    </div>
  </div>
  <div class="hero-foot">
    <span data-k="hero_f1">48h quote</span>
    <span class="hf-sep">·</span>
    <span data-k="hero_f2">MOQ from 50 m</span>
    <span class="hf-sep">·</span>
    <span data-k="hero_f3">Ships worldwide</span>
    <span class="hf-sep">·</span>
    <span data-k="hero_f4">12 years</span>
  </div>
</section>

<!-- CATALOG -->
<section class="catalog-sec" id="catalog">
  <div class="sec-container">
    <p class="sec-eyebrow" data-k="cat_label">What we make</p>
    <h2 class="sec-title" data-k="cat_h">Our catalog.</h2>
    <p class="sec-sub" data-k="cat_sub">Select a material to start an inquiry.</p>
    <div class="fab-grid" id="fabGrid"></div>
  </div>
</section>

<!-- SHOWCASE -->
<section class="showcase-sec" id="showcase">
  <div class="sec-container sc-header-row">
    <div>
      <p class="sec-eyebrow" data-k="sc_label">From our factory</p>
      <h2 class="sec-title" data-k="sc_h">Recent work.</h2>
    </div>
    <div class="sc-filters" id="scFilters">
      <button class="scf active" data-f="all"        data-k="scf_all">All</button>
      <button class="scf"        data-f="garment"    data-k="scf_gar">Garments</button>
      <button class="scf"        data-f="fabric"     data-k="scf_fab">Fabrics</button>
      <button class="scf"        data-f="embroidery" data-k="scf_emb">Embroidery</button>
    </div>
  </div>
  <div class="sc-track-wrap">
    <div class="sc-track" id="scTrack"></div>
  </div>
  <p class="sc-empty" id="scEmpty" style="display:none">No items yet.</p>
</section>

<!-- INQUIRY -->
<section class="inq-sec" id="inquiry">
  <div class="sec-container inq-layout">
    <div class="inq-left">
      <p class="sec-eyebrow" data-k="inq_label">Start your order</p>
      <h2 class="sec-title inq-title" data-k="inq_h">Get a quote<br><em>in 48 hours.</em></h2>
      <ul class="inq-facts">
        <li data-k="ps1d">Share photos, sketches or samples.</li>
        <li data-k="ps2d">We reply within 48 hours with options & price.</li>
        <li data-k="ps3d">Sample shipped to you before bulk production.</li>
      </ul>

      <!-- Direct contact channels -->
      <div class="inq-channels">
        <p class="inq-ch-label">Or reach us directly</p>
        <a class="inq-ch-btn" href="mailto:hello@dongxi.io">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="2" y="4" width="16" height="12" rx="1.5"/><path d="M2 5l8 6 8-6"/></svg>
          hello@dongxi.io
        </a>
        {WA && (
          <a class="inq-ch-btn" href={`https://wa.me/${WA}?text=Hi%2C%20I%20found%20DONGXI%20and%20would%20like%20to%20inquire.`} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        )}
        {TG && (
          <a class="inq-ch-btn" href={`https://t.me/${TG}`} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Telegram
          </a>
        )}
      </div>
    </div>
    <form id="iqForm" class="inq-form" novalidate>
      <div class="iq-row two-col">
        <div>
          <label class="iq-label" data-k="f_name">Name *</label>
