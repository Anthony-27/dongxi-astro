---
import Base    from '../layouts/Base.astro';
import { getProducts, urlFor } from '../lib/sanity';

const products = await getProducts();
const SNIPCART = import.meta.env.PUBLIC_SNIPCART_KEY ?? 'NWFlYjg0ZDgtOWFiNC00MmM3LWEwY2UtYWU5MWY4ZWJiZWI4NjM5MTQyNDY2NzQ3NTQ3MzA4';
---
<Base
  title="Shop — Ready-to-Ship Fabrics & Garments | DONGXI"
  description="Ready-to-ship fabrics, swatch bundles & sample pieces direct from Guangzhou. Silk, lace, embroidery & more."
  ogUrl="https://dongxi.io/shop"
>
  <slot slot="head">
    <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.3.3/default/snipcart.css">
  </slot>

  <!-- TOPBAR -->
  <header class="topbar">
    <a href="/" class="logo"><span class="logo-pip"></span>DONGXI</a>
    <div class="bar-r">
      <a href="/" class="tcta tcta-ghost" style="color:rgba(240,235,224,.6);">← dongxi.io</a>
      <button class="tcta snipcart-checkout">
        Cart <span class="snipcart-items-count"></span>
        <span class="cart-sub">order # emailed</span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="shop-hero">
    <div class="content-w">
      <div class="shop-hero-inner">
        <div>
          <div class="sec-label">Ready to ship · 现货直发</div>
          <h1 class="shop-h1">Fabric.<br><em>In stock.</em></h1>
        </div>
        <p class="shop-note">
          Stock fabrics, swatch bundles & small-batch pieces.<br>
          Ships from Guangzhou · DHL / sea freight.<br>
          <a href="/#inquiry">Need custom production? →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="shop-ticker">
    <div class="shop-ticker-inner">
      <span>Ready to Ship</span><span class="dot">·</span>
      <span>Silk · Lace · Jacquard · Embroidery</span><span class="dot">·</span>
      <span>Ships from Guangzhou</span><span class="dot">·</span>
      <span>DHL Express & Sea Freight</span><span class="dot">·</span>
      <span>B2B Direct Factory</span><span class="dot">·</span>
      <span>Ready to Ship</span><span class="dot">·</span>
      <span>Silk · Lace · Jacquard · Embroidery</span><span class="dot">·</span>
      <span>Ships from Guangzhou</span><span class="dot">·</span>
      <span>DHL Express & Sea Freight</span><span class="dot">·</span>
      <span>B2B Direct Factory</span><span class="dot">·</span>
    </div>
  </div>

  <!-- SHIPPING ESTIMATOR + POLICY -->
  <div class="ship-bar">
    <div class="content-w ship-inner">
      <span class="ship-label">🚚 Estimate shipping</span>

      <select class="ship-select" id="shipRegion">
        <option value="">— destination —</option>
        <optgroup label="Asia">
          <option value="10|8|1-2 days">Hong Kong / Macau</option>
          <option value="28|10|3-4 days">East Asia (Japan, Korea, Taiwan)</option>
          <option value="22|9|3-5 days">Southeast Asia</option>
          <option value="30|11|4-5 days">South Asia (India, Pakistan…)</option>
          <option value="38|12|5-6 days">Central Asia</option>
        </optgroup>
        <optgroup label="Middle East">
          <option value="38|12|4-6 days">UAE, Saudi Arabia, Qatar…</option>
        </optgroup>
        <optgroup label="Europe">
          <option value="48|15|5-7 days">Western Europe</option>
          <option value="52|15|6-8 days">Eastern Europe</option>
        </optgroup>
        <optgroup label="Americas">
          <option value="55|16|5-7 days">United States / Canada</option>
          <option value="60|16|7-9 days">Latin America</option>
        </optgroup>
        <optgroup label="Oceania & Africa">
          <option value="50|15|5-7 days">Australia / New Zealand</option>
          <option value="65|16|7-10 days">Africa</option>
        </optgroup>
      </select>

      <select class="ship-select ship-select-sm" id="shipQty">
        <option value="">— qty / weight —</option>
        <optgroup label="Fabric (by metre)">
          <option value="0.3">1–5 m (samples)</option>
          <option value="1.5">5–20 m</option>
          <option value="4">20–50 m</option>
          <option value="8">50–100 m</option>
          <option value="18">100–200 m</option>
          <option value="40">200 m+</option>
        </optgroup>
        <optgroup label="Garments (pieces)">
          <option value="1">1–5 pcs</option>
          <option value="3">5–20 pcs</option>
          <option value="8">20–50 pcs</option>
          <option value="20">50–100 pcs</option>
          <option value="45">100 pcs+</option>
        </optgroup>
      </select>

      <div class="ship-result-wrap">
        <span class="ship-result" id="shipResult"></span>
        <span class="ship-bulk" id="shipBulk"></span>
      </div>
      <span class="ship-note">DHL Express est. · duties not included</span>
    </div>
  </div>

  <!-- SHIPPING POLICY PANEL -->
  <div class="ship-policy">
    <div class="content-w ship-policy-inner">
      <div class="sp-block">
        <div class="sp-icon">📦</div>
        <div>
          <div class="sp-title">Standard Shipping</div>
          <div class="sp-desc">DHL Express from Guangzhou · Tracked door-to-door · Quoted after order based on weight & destination</div>
        </div>
      </div>
      <div class="sp-block">
        <div class="sp-icon">🚢</div>
        <div>
          <div class="sp-title">Bulk Orders — Sea Freight Available</div>
          <div class="sp-desc">Ordering large quantities? Sea freight saves 60–80% vs air. <a href="/#inquiry">Contact us</a> to arrange before placing your order.</div>
        </div>
      </div>
      <div class="sp-block">
        <div class="sp-icon">🏛️</div>
        <div>
          <div class="sp-title">Import Duties & Taxes</div>
          <div class="sp-desc">Not included in our prices. Assessed by your country's customs on arrival — payable by recipient. DHL will notify you of any charges. This is standard for international B2B shipments.</div>
        </div>
      </div>
      <div class="sp-block">
        <div class="sp-icon">🔖</div>
        <div>
          <div class="sp-title">Order Reference Number</div>
          <div class="sp-desc">Every order gets a unique reference number emailed to you. Quote it when contacting us about shipping, tracking or changes.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- FILTER + GRID -->
  <section class="shop-body">
    <div class="content-w">
      <div class="filter-row" id="filters">
        <button class="fp on" data-f="all">All</button>
        <button class="fp" data-f="fabric">Fabrics</button>
        <button class="fp" data-f="sample">Swatch bundles</button>
        <button class="fp" data-f="garment">Garments</button>
        <button class="fp" data-f="trimming">Trimmings 辅料</button>
      </div>

      {products.length === 0 ? (
        <p class="empty">Products coming soon — <a href="/#inquiry">send an inquiry</a> in the meantime.</p>
      ) : (
        <div class="prod-grid" id="prodGrid">
          {products.map((p: any) => {
            const imgs: string[] = p.images?.map((img: any) =>
              urlFor(img).width(600).auto('format').url()
            ) ?? [];
            const videoUrl = p.video?.asset?.url ?? null;
            const badge = p.badge
              ? `<span class="pc-badge b-${p.badge}">${p.badge.toUpperCase()}</span>`
              : '';
            return (
              <div class="pc" data-cat={p.category}>
                <div class="pc-media">
                  <div class="pc-slides" id={`sl-${p._id}`}>
                    {videoUrl && (
                      <div class="pc-slide">
                        <video src={videoUrl} autoplay muted loop playsinline></video>
                      </div>
                    )}
                    {imgs.map((src: string) => (
                      <div class="pc-slide">
                        <img src={src} alt={p.name} loading="lazy">
                      </div>
                    ))}
                  </div>
                  {imgs.length + (videoUrl ? 1 : 0) > 1 && (
                    <div class="pc-dots">
                      {[...(videoUrl ? [0] : []), ...imgs.map((_: any, i: number) => i + (videoUrl ? 1 : 0))].map((i: number) => (
                        <div class={`pc-dot${i === 0 ? ' on' : ''}`}></div>
                      ))}
                    </div>
                  )}
                  {imgs.length + (videoUrl ? 1 : 0) > 1 && (
                    <>
                      <button class="pc-nav prev">&#8249;</button>
                      <button class="pc-nav next">&#8250;</button>
                    </>
                  )}
                  <Fragment set:html={badge} />
                </div>
                <div class="pc-info">
                  <div class="pc-cat">
                    {p.collection && <span class="pc-season">{p.collection} · </span>}
                    {p.category}
                  </div>
                  <div class="pc-name">{p.name}</div>
                  {p.moq && <div class="pc-moq">{p.moq}</div>}
                  {p.composition && <div class="pc-comp">{p.composition}</div>}
                  {(p.fabricWidth || p.gsm) && (
                    <div class="pc-spec">
                      {p.fabricWidth && <span>{p.fabricWidth} cm wide</span>}
                      {p.fabricWidth && p.gsm && <span class="pc-spec-dot">·</span>}
                      {p.gsm && <span>{p.gsm} GSM</span>}
                    </div>
                  )}
                  <div class="pc-price-row">
                    <span class="pc-price">${p.price.toFixed(2)}</span>
                    <span class="pc-unit">{p.unit}</span>
                  </div>
                  <button
                    class="pc-add snipcart-add-item"
                    data-item-id={p.slug}
                    data-item-price={p.price.toFixed(2)}
                    data-item-url="https://dongxi.io/shop"
                    data-item-description={p.description ?? ''}
                    data-item-name={p.name}
                    data-item-image={imgs[0] ?? ''}
                    data-item-weight={(() => {
                      // Fabric: GSM × width(m) ÷ 1000 × 1.2 packaging factor
                      if (p.gsm && p.fabricWidth)
                        return Math.round(p.gsm * (p.fabricWidth / 100) / 1000 * 1.2 * 1000) / 1000;
                      // Garment/trimming: direct weight
                      if (p.weightPerUnit) return p.weightPerUnit;
                      // Fallback by category
                      return p.category === 'garment'  ? 0.35 :
                             p.category === 'trimming' ? 0.10 :
                             p.category === 'sample'   ? 0.20 : 0.15;
                    })()}
                    data-item-weight-unit="kg"
                  >
                    Add to Cart
                  </button>
                  <p class="pc-ship-note">DHL Express · shipping quoted after order</p>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- DUTIES NOTE -->
  <div class="duties-note">
    <p>Prices in USD &nbsp;·&nbsp; Shipping quoted after order based on weight &amp; destination &nbsp;·&nbsp; Import duties &amp; taxes borne by recipient &nbsp;·&nbsp; Ships from Guangzhou, China</p>
    <p class="duties-order">⚠️ <b>Import duties & local taxes are not included</b> — they are assessed by your country's customs and payable by the recipient upon arrival. DHL will notify you of any applicable charges. For duty rate estimates, check your country's customs authority website.</p>
    <p class="duties-order">🔖 A unique <b>order reference number</b> is emailed upon checkout — quote it for any shipping or product queries: <a href="mailto:hello@dongxi.io">hello@dongxi.io</a></p>
  </div>

  <!-- INQUIRY BANNER -->
  <div class="inq-banner">
    <div class="content-w">
      <h2>Need a <em>custom order?</em></h2>
      <p>From photo or sample · Bulk production · 48hr quote</p>
      <a href="/#inquiry" class="inq-cta">Start an Inquiry →</a>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="shop-foot">
    <span>DONGXI · 广州东西 · hello@dongxi.io</span>
    <span>© 2025 All rights reserved</span>
  </footer>

  <!-- Snipcart -->
  <div hidden id="snipcart" data-api-key={SNIPCART} data-currency="usd"></div>
  <script async src="https://cdn.snipcart.com/themes/v3.3.3/default/snipcart.js"></script>
</Base>

<style>
body { background: var(--paper); color: var(--ink); }

/* HERO */
.shop-hero {
  padding: 110px 0 0;
  background: var(--ink);
  color: var(--paper);
  border-bottom: 1px solid rgba(240,235,224,.08);
}
.shop-hero-inner {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
  padding-bottom: 48px;
}
.shop-h1 {
  font-size: clamp(48px,8vw,96px);
  font-weight: 400;
  line-height: 1.0;
  color: var(--paper);
}
.shop-h1 em { font-style: italic; color: var(--rust); }
.shop-note {
  font-family: 'Azeret Mono', monospace;
  font-size: 10px;
  line-height: 2;
  color: rgba(240,235,224,.4);
  max-width: 300px;
  text-align: right;
}
.shop-note a { color: var(--rust); text-decoration: none; }
@media(max-width:680px) { .shop-note { text-align:left; max-width:100%; } }

/* TICKER STRIP */
.shop-ticker {
  border-top: 1px solid rgba(240,235,224,.08);
  overflow: hidden;
  white-space: nowrap;
  padding: 10px 0;
}
.shop-ticker-inner {
  display: inline-flex;
  gap: 0;
  animation: ticker 22s linear infinite;
}
.shop-ticker span {
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(240,235,224,.22);
  padding: 0 32px;
}
.shop-ticker span.dot { color: var(--rust); padding: 0 4px; }
@keyframes ticker { from { transform: translateX(0) } to { transform: translateX(-50%) } }

/* BODY */
.shop-body { padding: 0 0 100px; }
.filter-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  padding: 36px 0 28px;
  border-bottom: 1px solid var(--line);
  margin-bottom: 32px;
}
.fp {
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: 8px 18px;
  background: transparent;
  border: 1px solid rgba(28,25,20,.15);
  color: rgba(28,25,20,.38);
  cursor: none;
  transition: all .15s;
  border-radius: 100px;
}
.fp.on, .fp:hover { background: var(--rust); border-color: var(--rust); color: var(--paper); }

/* GRID */
.prod-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
@media(min-width:600px)  { .prod-grid { gap: 16px; } }
@media(min-width:960px)  { .prod-grid { grid-template-columns: repeat(3,1fr); gap: 20px; } }
@media(min-width:1280px) { .prod-grid { grid-template-columns: repeat(4,1fr); } }

/* CARD */
.pc {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 4px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform .25s, box-shadow .25s;
}
.pc:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(28,25,20,.12); }
.pc-media { position: relative; aspect-ratio: 3/4; overflow: hidden; background: #f5f3ef; }
.pc-slides { display:flex; width:100%; height:100%; overflow-x:scroll; scroll-snap-type:x mandatory; scrollbar-width:none; }
.pc-slides::-webkit-scrollbar { display:none; }
.pc-slide { flex:0 0 100%; scroll-snap-align:start; }
.pc-slide img, .pc-slide video { width:100%; height:100%; object-fit:cover; display:block; transition: transform .4s; }
.pc:hover .pc-slide img { transform: scale(1.04); }
.pc-dots { position:absolute; bottom:12px; left:50%; transform:translateX(-50%); display:flex; gap:5px; pointer-events:none; z-index:2; }
.pc-dot { width:4px; height:4px; border-radius:50%; background:rgba(255,255,255,.4); transition:background .2s; }
.pc-dot.on { background:#fff; }
.pc-nav { position:absolute; top:50%; transform:translateY(-50%); background:rgba(28,25,20,.55); border:none; color:#fff; width:32px; height:32px; border-radius:50%; align-items:center; justify-content:center; cursor:none; z-index:3; font-size:16px; transition:background .15s; display:none; backdrop-filter:blur(4px); }
.pc-nav:hover { background:var(--rust); }
.pc-nav.prev { left:10px; } .pc-nav.next { right:10px; }
@media(hover:hover) { .pc:hover .pc-nav { display:flex; } }
.pc-badge { position:absolute; top:12px; left:12px; font-family:'Azeret Mono',monospace; font-size:8px; letter-spacing:.1em; text-transform:uppercase; padding:5px 10px; border-radius:2px; z-index:2; }
.b-new  { background: var(--ink); color: var(--paper); }
.b-hot  { background: var(--rust); color: var(--paper); }
.b-sale { background: #b5812a; color: #fff; }

/* CARD INFO */
.pc-info { padding: 14px 15px 16px; flex: 1; display: flex; flex-direction: column; }
.pc-cat  { font-family:'Azeret Mono',monospace; font-size:8px; letter-spacing:.14em; text-transform:uppercase; color:rgba(28,25,20,.28); }
.pc-season { color: var(--rust); font-weight:500; }
.pc-name { font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.35; margin-top: 5px; flex: 1; }
.pc-moq  { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(28,25,20,.3); margin-top:4px; }
.pc-comp     { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(28,25,20,.38); margin-top:3px; letter-spacing:.04em; }
.pc-spec     { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(28,25,20,.32); margin-top:3px; letter-spacing:.04em; display:flex; gap:5px; flex-wrap:wrap; }
.pc-spec-dot { color:rgba(28,25,20,.18); }
.pc-price-row { display:flex; align-items:baseline; gap:5px; margin-top:12px; }
.pc-price { font-family:'Libre Baskerville',serif; font-size:20px; color:var(--ink); }
.pc-unit  { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(28,25,20,.35); }
.pc-add {
  margin-top: 12px;
  padding: 11px 0;
  width: 100%;
  background: var(--ink);
  color: var(--paper);
  font-family: 'Azeret Mono', monospace;
  font-size: 8px;
  letter-spacing: .16em;
  text-transform: uppercase;
  border: none;
  cursor: none;
  transition: background .15s, letter-spacing .15s;
  border-radius: 3px;
}
.pc-add:hover { background: var(--rust); letter-spacing: .22em; }
.pc-ship-note { font-family:'Azeret Mono',monospace; font-size:8px; color:rgba(28,25,20,.28); text-align:center; margin-top:6px; letter-spacing:.04em; }

.empty { padding:80px 0; font-family:'Azeret Mono',monospace; font-size:11px; color:rgba(28,25,20,.35); }
.empty a { color: var(--rust); }

/* BOTTOM */
.inq-banner {
  background: var(--ink);
  color: var(--paper);
  padding: 72px 0;
  text-align: center;
}
.inq-banner h2 { font-size:clamp(28px,4vw,52px); font-weight:400; margin-bottom:12px; }
.inq-banner h2 em { color: var(--rust); font-style: italic; }
.inq-banner p { font-family:'Azeret Mono',monospace; font-size:10px; color:rgba(240,235,224,.3); margin-bottom:32px; letter-spacing:.06em; }
.inq-cta {
  display: inline-block;
  padding: 15px 44px;
  background: var(--rust);
  color: var(--paper);
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background .15s, letter-spacing .15s;
  border-radius: 2px;
}
.inq-cta:hover { background: var(--rust2); letter-spacing: .24em; }
.shop-foot {
  background: var(--ink);
  border-top: 1px solid rgba(240,235,224,.06);
  padding: 24px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}
.shop-foot span { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(240,235,224,.2); letter-spacing:.06em; }
:root { --color-primary: #c04b28; }

/* CART SUB LABEL */
.cart-sub { display:block; font-size:7px; letter-spacing:.08em; opacity:.45; margin-top:1px; }

/* SHIPPING ESTIMATOR */
.ship-bar {
  background: #f2ede8;
  border-bottom: 1px solid var(--line);
  padding: 14px 0;
}
.ship-inner {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.ship-label {
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(28,25,20,.5);
  white-space: nowrap;
}
.ship-select {
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  letter-spacing: .06em;
  padding: 8px 12px;
  border: 1px solid rgba(28,25,20,.18);
  background: #fff;
  color: var(--ink);
  cursor: pointer;
  border-radius: 2px;
  min-width: 220px;
}
.ship-select-sm { min-width: 160px !important; }
.ship-result-wrap { display: flex; flex-direction: column; gap: 4px; }
.ship-result {
  font-family: 'Libre Baskerville', serif;
  font-size: 18px;
  color: var(--ink);
  font-weight: 400;
}
.ship-result.has-val { color: var(--rust); }
.ship-bulk {
  font-family: 'Azeret Mono', monospace;
  font-size: 8px;
  color: var(--rust);
  letter-spacing: .04em;
  max-width: 320px;
  line-height: 1.7;
}
.ship-note {
  font-family: 'Azeret Mono', monospace;
  font-size: 8px;
  color: rgba(28,25,20,.3);
  letter-spacing: .06em;
}
@media(max-width:700px) { .ship-inner { flex-wrap: wrap; gap: 10px; } .ship-select, .ship-select-sm { min-width: calc(50% - 5px) !important; } }

/* SHIPPING POLICY PANEL */
.ship-policy {
  background: var(--ink);
  color: var(--paper);
  padding: 32px 0;
  border-bottom: 1px solid rgba(248,245,241,.06);
}
.ship-policy-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
@media(max-width:960px) { .ship-policy-inner { grid-template-columns: repeat(2,1fr); gap: 20px; } }
@media(max-width:560px)  { .ship-policy-inner { grid-template-columns: 1fr; } }
.sp-block {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.sp-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
.sp-title {
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--paper);
  margin-bottom: 6px;
}
.sp-desc {
  font-family: 'Azeret Mono', monospace;
  font-size: 9px;
  line-height: 1.8;
  color: rgba(248,245,241,.38);
  letter-spacing: .03em;
}
.sp-desc a { color: var(--rust); text-decoration: none; }
.sp-desc a:hover { text-decoration: underline; }

/* DUTIES NOTE */
.duties-note { text-align:center; padding:20px 24px; border-top:1px solid var(--line); }
.duties-note p { font-family:'Azeret Mono',monospace; font-size:9px; color:rgba(28,25,20,.3); letter-spacing:.06em; margin:0; line-height:2; }
.duties-order { color:rgba(28,25,20,.45) !important; margin-top:8px !important; }
.duties-order b { color:rgba(28,25,20,.6); }
.duties-order a { color:var(--rust); text-decoration:none; }
</style>

<script>
// Shipping estimator — base + per-kg rate
// option value format: "base|perKg|days"
function calcShipping() {
  const regionEl = document.getElementById('shipRegion') as HTMLSelectElement;
  const qtyEl    = document.getElementById('shipQty')    as HTMLSelectElement;
  const resultEl = document.getElementById('shipResult')!;
  const bulkEl   = document.getElementById('shipBulk')!;

  const region = regionEl?.value;
  const kg     = parseFloat(qtyEl?.value ?? '');

  if (!region || !kg) {
    resultEl.textContent = ''; resultEl.classList.remove('has-val');
    bulkEl.textContent = '';
    return;
  }

  const [baseStr, perKgStr, days] = region.split('|');
  const base  = parseFloat(baseStr);
  const perKg = parseFloat(perKgStr);

  // first 2kg included in base, then per-kg after
  const extra = Math.max(0, kg - 2) * perKg;
  const total = Math.ceil((base + extra) * 2);

  resultEl.textContent = `est. $${total}  ·  ${days}`;
  resultEl.classList.add('has-val');

  // Suggest sea freight for heavy shipments
  if (kg >= 18) {
    bulkEl.textContent = '🚢 Large order — sea freight may save 60–80%. Contact us before ordering.';
  } else {
    bulkEl.textContent = '';
  }
}
document.getElementById('shipRegion')?.addEventListener('change', calcShipping);
document.getElementById('shipQty')?.addEventListener('change', calcShipping);

// Filter
document.getElementById('filters')?.querySelectorAll('.fp').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.fp').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    const f = (btn as HTMLElement).dataset.f ?? 'all';
    document.querySelectorAll<HTMLElement>('.pc').forEach(card => {
      card.style.display = (f === 'all' || card.dataset.cat === f) ? '' : 'none';
    });
  });
});

// Slide mechanics
document.querySelectorAll('.pc-slides').forEach(sl => {
  const card = sl.closest('.pc');
  const dots = [...(card?.querySelectorAll('.pc-dot') ?? [])];
  sl.addEventListener('scroll', () => {
    const idx = Math.round(sl.scrollLeft / sl.clientWidth);
    dots.forEach((d, i) => d.classList.toggle('on', i === idx));
  }, { passive: true });
  card?.querySelectorAll('.pc-nav').forEach(btn => {
    btn.addEventListener('click', () => {
      const dir = btn.classList.contains('next') ? 1 : -1;
      const cur = Math.round(sl.scrollLeft / sl.clientWidth);
      sl.scrollTo({ left: (cur + dir) * sl.clientWidth, behavior: 'smooth' });
    });
  });
});
</script>
